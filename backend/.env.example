# Environment variables for the audit app backend
DATABASE_URL=postgresql://postgres:password@localhost:5432/audit_app
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=audit-app-documents
AWS_REGION=us-east-1

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379

# Sentry Configuration (error tracking)
SENTRY_DSN=your-sentry-dsn

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@auditgava.com
FRONTEND_URL=http://localhost:3000

# Application Settings
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# Admin API Authentication
# (Legacy — the ADMIN_API_AUTH_REQUIRED toggle is no longer read.
# Admin endpoints now always go through ``require_admin`` from
# ``supabase_auth.py``, which verifies Supabase-issued JWTs.)
ADMIN_API_AUTH_REQUIRED=false

# Supabase admin auth — REQUIRED for /api/v1/admin/* to work
# ----------------------------------------------------------
# SUPABASE_URL: your project URL, e.g. https://abcdefgh.supabase.co
#   Used to fetch the JWKS for verifying ECC-signed access tokens.
SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY: from Supabase dashboard → Settings → API
# → "service_role" (the secret one, NOT anon). Bypasses RLS — keep
# server-side, never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET: ONLY needed if your project still uses the
# legacy HS256 symmetric secret (Settings → API → "Legacy JWT
# Secret" tab). Modern projects with asymmetric signing keys (the
# default in 2025+) don't need this — verification happens via the
# JWKS endpoint above.
SUPABASE_JWT_SECRET=

# Seeding Configuration
SEED_RATE_LIMIT=60/min
SEED_TIMEOUT_SECONDS=30.0
SEED_MAX_RETRIES=3
SEED_DRY_RUN_DEFAULT=false
SEED_BUDGET_DEFAULT_CURRENCY=KES

# Data Source URLs (use file:// for local data during development)
# Production transition guide: See docs/production-data-sources.md
# Supported schemes: file://, https://, http://
# Note: file:// paths are relative to CWD — run seeder from backend/ directory
SEED_POPULATION_DATASET_URL=file://seeding/real_data/population.json
SEED_BUDGETS_DATASET_URL=file://seeding/real_data/budgets.json
SEED_AUDITS_DATASET_URL=file://seeding/real_data/audits.json
SEED_ECONOMIC_INDICATORS_DATASET_URL=file://seeding/real_data/economic_indicators.json
SEED_NATIONAL_DEBT_DATASET_URL=file://seeding/real_data/national_debt.json
SEED_DEBT_TIMELINE_DATASET_URL=file://seeding/real_data/debt_timeline.json
SEED_FISCAL_SUMMARY_DATASET_URL=file://seeding/real_data/fiscal_summary.json
SEED_REVENUE_BY_SOURCE_DATASET_URL=file://seeding/real_data/revenue_by_source.json
SEED_NATIONAL_BUDGET_EXECUTION_DATASET_URL=file://seeding/real_data/national_budget_execution.json
SEED_PENDING_BILLS_DATASET_URL=file://seeding/fixtures/pending_bills.json
SEED_LEARNING_HUB_DATASET_URL=file://seeding/fixtures/learning_hub.json

# Production data sources (uncomment and update when ready to use real APIs)
# See docs/data-sources.md for official government portal URLs
# SEED_BUDGETS_DATASET_URL=https://opendata.go.ke/api/views/xyz/rows.json
# SEED_AUDITS_DATASET_URL=https://oagkenya.go.ke/reports/data.json
# SEED_POPULATION_DATASET_URL=https://www.knbs.or.ke/data/population.json
# SEED_ECONOMIC_INDICATORS_DATASET_URL=https://www.knbs.or.ke/data/economic-indicators.json
# SEED_NATIONAL_DEBT_DATASET_URL=https://treasury.go.ke/debt-bulletins/latest.json
# SEED_LEARNING_HUB_DATASET_URL=https://transparency.go.ke/learning/questions.json
