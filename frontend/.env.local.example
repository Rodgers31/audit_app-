NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Kenya Audit Transparency
NEXT_PUBLIC_APP_VERSION=1.0.0

# Site URL – set to your production domain (used for Supabase auth redirect URLs)
# Leave blank for local dev (falls back to window.location.origin)
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Supabase – get these from https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
